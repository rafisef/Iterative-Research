# ── Cursor ────────────────────────────────────────────────────────────────────
# .cursor/rules/

# ── Python virtual environments ───────────────────────────────────────────────
ai-research-env/
venv/
.venv/
env/
.env/

# ── Python cache & compiled files ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Distribution / packaging ──────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ── Experiment outputs (generated at runtime) ─────────────────────────────────
outputs/
logs/
results.jsonl
results-*.jsonl

# ── Secrets & environment files ───────────────────────────────────────────────
.env
.env.*
*.env
secrets.yaml
secrets.yml

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Editor & IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
